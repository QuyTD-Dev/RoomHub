@using Domain.Enums
@model Application.DTOs.RoomPosts.EditRoomViewModel

@{
    ViewData["Title"] = "Edit Room Post";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 border-top border-primary border-4">
        <div class="card-header bg-white pb-0">
            <h4 class="text-primary mb-3"><i class="bi bi-pencil-square"></i> Edit Room: @Model.Title</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                <div class="row">
                    <!-- Left Column: Core Info -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="Title" class="form-label fw-bold"></label>
                        <input asp-for="Title" class="form-control" placeholder="e.g. Beautiful room with balcony" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="RoomNumber" class="form-label fw-bold"></label>
                        <input asp-for="RoomNumber" class="form-control" />
                        <span asp-validation-for="RoomNumber" class="text-danger small"></span>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label asp-for="FloorId" class="form-label fw-bold"></label>
                        <select asp-for="FloorId" class="form-select">
                            <option value="">-- Select Floor --</option>
                            @if(Model.AvailableFloors != null)
                            {
                                foreach(var floor in Model.AvailableFloors)
                                {
                                    <option value="@floor.Id">@floor.Building.Name - Floor @floor.FloorNumber</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="FloorId" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="RoomType" class="form-label fw-bold"></label>
                        <select asp-for="RoomType" asp-items="Html.GetEnumSelectList<RoomType>()" class="form-select"></select>
                        <span asp-validation-for="RoomType" class="text-danger small"></span>
                    </div>
                    
                    <div class="col-md-3 mb-3">
                        <label asp-for="Status" class="form-label fw-bold"></label>
                        <select asp-for="Status" asp-items="Html.GetEnumSelectList<RoomStatus>()" class="form-select"></select>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="BasePrice" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <input asp-for="BasePrice" type="number" step="0.01" class="form-control" />
                            <span class="input-group-text">₫</span>
                        </div>
                        <span asp-validation-for="BasePrice" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="SurfaceArea" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <input asp-for="SurfaceArea" type="number" step="0.1" class="form-control" />
                            <span class="input-group-text">m&sup2;</span>
                        </div>
                        <span asp-validation-for="SurfaceArea" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="MaxCapacity" class="form-label fw-bold"></label>
                        <div class="input-group">
                            <input asp-for="MaxCapacity" type="number" class="form-control" />
                            <span class="input-group-text"><i class="bi bi-people"></i></span>
                        </div>
                        <span asp-validation-for="MaxCapacity" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12 mb-3">
                        <label asp-for="Description" class="form-label fw-bold"></label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Describe the room details nicely..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12 mb-4">
                        <label class="form-label fw-bold text-primary mb-2">Amenities & Features</label>
                        <div class="card bg-light border-0">
                            <div class="card-body p-3">
                                <div class="form-check form-switch custom-switch mb-3">
                                    <input class="form-check-input" type="checkbox" asp-for="IsFurnished" id="IsFurnishedCheck" />
                                    <label class="form-check-label fw-bold" for="IsFurnishedCheck">
                                        Is Fully Furnished?
                                    </label>
                                </div>
                                
                                @if (Model.AvailableAmenities != null && Model.AvailableAmenities.Any())
                                {
                                    <div class="row g-3">
                                        @foreach (var amenity in Model.AvailableAmenities)
                                        {
                                            <div class="col-md-4 col-sm-6">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" name="SelectedAmenityIds" 
                                                           value="@amenity.Id" id="amenity_@amenity.Id"
                                                           @(Model.SelectedAmenityIds.Contains(amenity.Id) ? "checked" : "") />
                                                    <label class="form-check-label" for="amenity_@amenity.Id">
                                                        @if (!string.IsNullOrEmpty(amenity.IconUrl))
                                                        {
                                                            <i class="@amenity.IconUrl me-1 text-secondary"></i>
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-check2-square me-1 text-secondary"></i>
                                                        }
                                                        @amenity.Name
                                                    </label>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="text-muted small italic">No additional amenities available to select.</div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-2">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-check-circle me-1"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
