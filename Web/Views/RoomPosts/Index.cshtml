@model IEnumerable<Application.DTOs.RoomPosts.RoomListViewModel>
@{
    ViewData["Title"] = "My Room Posts";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>My Room Posts (Landlord)</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Create New Post
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th>Room No.</th>
                            <th>Price</th>
                            <th>Area</th>
                            <th>Status</th>
                            <th>Amenities</th>
                            <th>Date Posted</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@item.Title</strong>
                                        <div class="text-muted small">@item.Address</div>
                                    </td>
                                    <td>@item.RoomNumber</td>
                                    <td>@item.BasePrice.ToString("C")</td>
                                    <td>@(item.SurfaceArea?.ToString("0.##") ?? "N/A") m&sup2;</td>
                                    <td>
                                        @{
                                            var badgeClass = item.Status switch
                                            {
                                                Domain.Enums.RoomStatus.Active => "bg-success",
                                                Domain.Enums.RoomStatus.Hidden => "bg-secondary",
                                                Domain.Enums.RoomStatus.Available => "bg-info text-dark",
                                                Domain.Enums.RoomStatus.Occupied => "bg-primary",
                                                _ => "bg-warning text-dark"
                                            };
                                        }
                                        <span class="badge @badgeClass">@item.Status</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">@item.AmenityCount items</span>
                                    </td>
                                    <td>@item.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</td>
                                    <td class="text-end">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" target="_blank">
                                            View
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                            Edit
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="confirmDelete(this.form)">
                                                Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-4 text-muted">
                                    No room posts found. Click "Create New Post" to add one!
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete(form) {
            if (confirm("Are you sure you want to delete this room post? This action cannot be undone.")) {
                form.submit();
            }
        }
    </script>
}
