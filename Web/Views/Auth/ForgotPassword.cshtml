@model Web.Models.ForgotPasswordViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html class="light" lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>RoomHub | Forgot Password</title>

    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#F97316",
                        "primary-hover": "#ea580c",
                        "background-light": "#F8FAFC",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"],
                        "poppins": ["Poppins", "sans-serif"],
                    },
                    borderRadius: {
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    boxShadow: {
                        "orange-glow": "0 10px 25px -5px rgba(249, 115, 22, 0.3), 0 8px 10px -6px rgba(249, 115, 22, 0.1)",
                    }
                },
            },
        }
    </script>
    <style type="text/tailwindcss">
        body { font-family: 'Inter', sans-serif; }
        .split-screen { min-height: 100vh; display: flex; }
        .form-side { flex: 1; display: flex; flex-direction: column; background: white; }
        .image-side { flex: 1.2; position: relative; display: none; }
        @@media (min-width: 1024px) {
            .image-side { display: block; }
        }
    </style>
</head>

<body class="bg-background-light text-slate-900">

    <div class="split-screen">

        <!-- FORM SIDE -->
        <div class="form-side px-6 py-8 md:px-12 lg:px-20 relative">

            <!-- Main Form -->
            <div class="max-w-md w-full mx-auto my-auto py-12">

                <!-- Icon -->
                <div class="flex justify-center mb-8">
                    <div class="w-16 h-16 rounded-full bg-orange-50 flex items-center justify-center border border-orange-100">
                        <span class="material-symbols-outlined text-primary text-3xl font-light">key_visualizer</span>
                    </div>
                </div>

                <!-- Heading -->
                <div class="text-center mb-10">
                    <h1 class="text-3xl font-bold text-slate-900 font-poppins mb-3 tracking-tight">Quên mật khẩu?</h1>
                    <p class="text-slate-500">
                        Đừng lo lắng! Hãy nhập email liên kết với tài khoản của bạn và chúng tôi sẽ gửi mã OTP để đặt lại mật khẩu.
                    </p>
                </div>

                <!-- Validation Summary -->
                <div asp-validation-summary="All" class="text-red-500 text-sm mb-4"></div>

                <!-- Form -->
                <form asp-controller="Auth" asp-action="ForgotPassword" method="post" class="space-y-6">
                    @Html.AntiForgeryToken()

                    <div>
                        <label asp-for="Email" class="block text-sm font-semibold text-slate-700 mb-2">Địa chỉ Email</label>
                        <div class="relative group">
                            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                <span class="material-symbols-outlined text-slate-400 group-focus-within:text-primary transition-colors">mail</span>
                            </div>
                            <input asp-for="Email"
                                   class="block w-full pl-11 pr-4 py-3 border border-slate-200 rounded-xl bg-slate-50 focus:bg-white focus:ring-2 focus:ring-primary focus:border-primary transition-all text-slate-900 placeholder-slate-400 focus:outline-none"
                                   placeholder="ten@congty.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-red-500 text-sm mt-1 block"></span>
                    </div>

                    <button type="submit"
                            class="w-full py-3.5 px-4 bg-primary text-white font-bold rounded-xl shadow-orange-glow hover:bg-primary-hover hover:shadow-lg transition-all transform active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">
                        Gửi mã xác thực
                    </button>
                </form>

                <!-- Help text -->
                <div class="mt-8 text-center">
                    <p class="text-sm text-slate-500">
                        Đã nhớ lại mật khẩu?
                        <a asp-controller="Auth" asp-action="Login"
                           class="text-primary font-semibold hover:underline">Đăng nhập tại đây</a>.
                    </p>
                </div>

            </div>

        </div>

        <!-- IMAGE SIDE -->
        <div class="image-side">
            <img alt="Modern Architecture"
                 class="absolute inset-0 w-full h-full object-cover"
                 src="https://lh3.googleusercontent.com/aida-public/AB6AXuCgZ-03dhzDd6AP_Q1driO6Kx_pSJCAnfl_okWtl6OWEYKkrF1-3bc15zLdhfxB6e0eyLUjlZGOo5VMV57oarTGoS5TvD8XCOZm9lKxZIuqRgIzcF03KJDWSgiuXFes7Ynr4bHiUS52jzzyMAzjSwSE42qHmwQXBpgEKvNKP2THEd_HLvmRJ7RCboO6AE8b9LtEkBPLq7XDxbpF0-TGMfHrSVNYQi3vI-Km7YrcGfoRo2zJ_f4ABY15AKHBPitgvK7bi14tBqY-br1_" />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-slate-900/20 to-transparent"></div>
            <div class="absolute bottom-20 left-16 right-16">
                <h2 class="text-4xl font-bold text-white font-poppins leading-tight mb-4">
                    Khôi phục quyền truy cập tài khoản an toàn.
                </h2>
                <div class="h-1.5 w-20 bg-primary rounded-full mb-6"></div>
                <p class="text-slate-200 text-lg max-w-sm">
                    Tham gia cùng hàng ngàn chuyên gia quản lý danh mục bất động sản một cách dễ dàng và an toàn.
                </p>
            </div>
        </div>

    </div>

</body>

</html>
