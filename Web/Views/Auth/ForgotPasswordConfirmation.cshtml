@{
    Layout = null;
    var email = TempData.Peek("ResetEmail")?.ToString() ?? "your email";
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RoomHub - Check Your Email</title>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#F97316",
                        "primary-hover": "#ea580c",
                        "success": "#10B981",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"],
                        "poppins": ["Poppins", "sans-serif"],
                    },
                    borderRadius: {
                        "xl": "0.75rem",
                        "2xl": "1rem",
                        "full": "9999px"
                    },
                },
            },
        }
    </script>
    <style type="text/tailwindcss">
        body { font-family: 'Inter', sans-serif; }
        .split-screen-height { height: 100vh; }
    </style>
</head>

<body class="bg-white text-slate-900 font-display overflow-hidden">

    <div class="flex flex-col lg:flex-row split-screen-height">

        <!-- FORM SIDE -->
        <div class="w-full lg:w-1/2 flex flex-col justify-center px-8 sm:px-12 lg:px-24 xl:px-32 bg-white relative z-10">

            <div class="max-w-md w-full mx-auto lg:mx-0">

                <!-- Logo -->
                <div class="mb-12 flex items-center gap-2">
                    <div class="w-10 h-10 bg-primary rounded-lg flex items-center justify-center">
                        <span class="material-symbols-outlined text-white">domain</span>
                    </div>
                    <span class="text-2xl font-bold font-poppins tracking-tight text-slate-900">RoomHub</span>
                </div>

                <div class="flex flex-col items-start">

                    <!-- Success Icon -->
                    <div class="w-16 h-16 bg-emerald-50 rounded-full flex items-center justify-center mb-6">
                        <div class="w-12 h-12 bg-success rounded-full flex items-center justify-center">
                            <span class="material-symbols-outlined text-white text-3xl font-bold">check</span>
                        </div>
                    </div>

                    <h1 class="text-3xl font-bold text-slate-900 font-poppins mb-4">Kiểm tra email của bạn</h1>
                    <p class="text-slate-600 text-lg mb-8 leading-relaxed">
                        Chúng tôi đã gửi mã xác thực OTP đến
                        <span class="font-semibold text-slate-900">@email</span>.
                        Vui lòng kiểm tra hộp thư đến để tiếp tục.
                    </p>

                    <div class="w-full space-y-4">

                        <!-- Enter OTP Button - bước tiếp theo -->
                        <a asp-controller="Auth" asp-action="VerifyResetOtp"
                           class="w-full flex items-center justify-center gap-2 px-6 py-3.5 bg-primary text-white font-semibold rounded-xl hover:bg-primary-hover transition-all duration-200 shadow-md">
                            <span class="material-symbols-outlined text-xl">password</span>
                            Nhập mã OTP
                        </a>

                        <!-- Open Email App Button -->
                        <a href="mailto:"
                           class="w-full flex items-center justify-center gap-2 px-6 py-3.5 border-2 border-primary text-primary font-semibold rounded-xl hover:bg-orange-50 transition-all duration-200">
                            <span class="material-symbols-outlined text-xl">mail</span>
                            Mở ứng dụng Email
                        </a>

                        <!-- Resend -->
                        <div class="text-center lg:text-left">
                            <p class="text-sm text-slate-500">
                                Không nhận được email?
                                <button id="resendBtn"
                                        type="button"
                                        data-email="@email"
                                        class="text-primary font-semibold hover:underline decoration-2 underline-offset-4 ml-1">
                                    Gửi lại mã
                                </button>
                                <span id="resendMessage" class="ml-2 text-emerald-600 font-medium hidden">Đã gửi!</span>
                            </p>
                        </div>

                    </div>

                </div>
            </div>

        </div>

        <!-- IMAGE SIDE -->
        <div class="hidden lg:block lg:w-1/2 relative overflow-hidden">
            <img alt="Professional Architectural Interior"
                 class="absolute inset-0 w-full h-full object-cover"
                 src="https://lh3.googleusercontent.com/aida-public/AB6AXuCvPC1hPvIcwjtxOMw1BnvTVP80DIcKw1GE_QGxRnx0YZ8lEQ2usbjhcbp4NnjJrFRl4PT6AzetijG1jgjP9mkO57cxdYlv6MZL8aZVWUJ9RQm3s6pLajUfdywwzmwGQ8NeSdLs4lohB5MCuBwXlajUodUE0V9NX6TSxeA4JoUM8uA9GKDgDeG5kmxPI4nly7Jmgqhx_AMTx9oDgLBqaGpkIivA3eUvZuMMXpkqlWPdkz_vuIXC4wFFbGzG0R-eAqMxRgTB7rO1NAvO" />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-slate-900/20 to-transparent"></div>
            <div class="absolute bottom-16 left-16 right-16">
                <div class="max-w-lg">
                    <h2 class="text-4xl font-bold text-white font-poppins mb-4 leading-tight">
                        Khôi phục quyền truy cập tài khoản an toàn.
                    </h2>
                    <div class="w-16 h-1 bg-primary mb-6"></div>
                    <p class="text-slate-200 text-lg">
                        Xác minh đa lớp của chúng tôi đảm bảo dữ liệu bất động sản và thông tin cá nhân của bạn được bảo vệ trong suốt quá trình khôi phục.
                    </p>
                </div>
            </div>
        </div>

    </div>

    <script>
        document.getElementById('resendBtn').addEventListener('click', async function () {
            const email = this.dataset.email;
            const btn = this;
            const msg = document.getElementById('resendMessage');

            btn.disabled = true;
            btn.textContent = 'Đang gửi...';

            try {
                const response = await fetch('@Url.Action("ResendForgotPasswordOtp", "Auth")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? ''
                    },
                    body: JSON.stringify({ email })
                });

                const data = await response.json();
                if (data.success) {
                    msg.textContent = 'Đã gửi!';
                    msg.classList.remove('hidden');
                    setTimeout(() => msg.classList.add('hidden'), 3000);
                }
            } catch (e) {
                console.error(e);
            } finally {
                btn.disabled = false;
                btn.textContent = 'Gửi lại mã';
            }
        });
    </script>

</body>

</html>
