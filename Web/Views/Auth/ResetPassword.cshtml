@model Web.Models.ResetPasswordViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RoomHub | Reset Password</title>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        "primary": "#F97316",
                        "primary-hover": "#ea580c",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"],
                        "poppins": ["Poppins", "sans-serif"],
                    },
                    boxShadow: {
                        "orange-glow": "0 10px 25px -5px rgba(249, 115, 22, 0.4), 0 8px 10px -6px rgba(249, 115, 22, 0.2)",
                    }
                },
            },
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; }
        ::-webkit-scrollbar { width: 0px; }
        /* Hide browser-native reveal button to avoid overlap with our custom eye icon */
        input::-ms-reveal,
        input::-ms-clear {
            display: none;
        }
    </style>
</head>

<body class="bg-white text-slate-900 font-display">

    <div class="min-h-screen w-full flex flex-col lg:flex-row">

        <!-- FORM SIDE -->
        <div class="w-full lg:w-[45%] flex flex-col p-6 sm:p-8 lg:p-12 xl:p-16 bg-white relative h-screen overflow-y-auto">

            <div class="w-full max-w-md mx-auto flex flex-col justify-center flex-grow mt-12 lg:mt-0">

                <!-- Icon -->
                <div class="mx-auto mb-8">
                    <div class="w-20 h-20 bg-orange-50 rounded-full flex items-center justify-center">
                        <span class="material-symbols-outlined text-primary" style="font-size:36px;">lock</span>
                    </div>
                </div>

                <!-- Heading -->
                <div class="text-center mb-10">
                    <h1 class="text-3xl font-bold text-slate-900 mb-3 font-poppins">Đặt mật khẩu mới</h1>
                    <p class="text-slate-500 text-sm sm:text-base">
                        Mật khẩu mới của bạn phải khác với các mật khẩu đã sử dụng trước đó.
                    </p>
                </div>

                <!-- Validation Summary -->
                <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm mb-4 text-center"></div>

                <!-- Hidden email field -->
                <form asp-controller="Auth" asp-action="ResetPassword" method="post" class="space-y-6">
                    @Html.AntiForgeryToken()

                    <input asp-for="Email" type="hidden" />

                    <div class="space-y-4">

                        <!-- New Password -->
                        <div class="space-y-1">
                            <label asp-for="NewPassword" class="block text-sm font-medium text-slate-700">Mật khẩu mới</label>
                            <div class="relative">
                                <input asp-for="NewPassword"
                                       id="newPassword"
                                       type="password"
                                       placeholder="••••••••"
                                       class="w-full h-12 pl-4 pr-12 rounded-xl border border-slate-200 bg-white text-slate-900 focus:border-primary focus:ring-primary focus:ring-2 outline-none transition-all placeholder:text-slate-300 shadow-sm" />
                                <button type="button" onclick="togglePassword('newPassword', 'eyeNew')"
                                        class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-primary transition-colors focus:outline-none">
                                    <span id="eyeNew" class="material-symbols-outlined" style="font-size:20px;">visibility</span>
                                </button>
                            </div>
                            <span asp-validation-for="NewPassword" class="text-red-500 text-xs mt-1 block"></span>
                        </div>

                        <!-- Confirm Password -->
                        <div class="space-y-1">
                            <label asp-for="ConfirmPassword" class="block text-sm font-medium text-slate-700">Xác nhận mật khẩu</label>
                            <div class="relative">
                                <input asp-for="ConfirmPassword"
                                       id="confirmPassword"
                                       type="password"
                                       placeholder="••••••••"
                                       class="w-full h-12 pl-4 pr-12 rounded-xl border border-slate-200 bg-white text-slate-900 focus:border-primary focus:ring-primary focus:ring-2 outline-none transition-all placeholder:text-slate-300 shadow-sm" />
                                <button type="button" onclick="togglePassword('confirmPassword', 'eyeConfirm')"
                                        class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-primary transition-colors focus:outline-none">
                                    <span id="eyeConfirm" class="material-symbols-outlined" style="font-size:20px;">visibility</span>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-red-500 text-xs mt-1 block"></span>
                        </div>

                    </div>

                    <!-- Password Requirements -->
                    <div class="pt-2">
                        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Yêu cầu mật khẩu</p>
                        <ul class="space-y-2" id="requirementsList">

                            <li id="req-length" class="flex items-center gap-3 text-sm text-slate-500 transition-colors">
                                <div class="w-5 h-5 rounded-full bg-slate-100 flex items-center justify-center flex-shrink-0 req-icon">
                                    <span class="w-1.5 h-1.5 rounded-full bg-slate-300 req-dot"></span>
                                </div>
                                <span>Ít nhất 8 ký tự</span>
                            </li>

                            <li id="req-special" class="flex items-center gap-3 text-sm text-slate-500 transition-colors">
                                <div class="w-5 h-5 rounded-full bg-slate-100 flex items-center justify-center flex-shrink-0 req-icon">
                                    <span class="w-1.5 h-1.5 rounded-full bg-slate-300 req-dot"></span>
                                </div>
                                <span>Ít nhất 1 ký tự đặc biệt</span>
                            </li>

                            <li id="req-number" class="flex items-center gap-3 text-sm text-slate-500 transition-colors">
                                <div class="w-5 h-5 rounded-full bg-slate-100 flex items-center justify-center flex-shrink-0 req-icon">
                                    <span class="w-1.5 h-1.5 rounded-full bg-slate-300 req-dot"></span>
                                </div>
                                <span>Ít nhất 1 chữ số</span>
                            </li>

                        </ul>
                    </div>

                    <button type="submit"
                            class="w-full h-14 flex items-center justify-center rounded-xl bg-primary text-white text-lg font-semibold shadow-orange-glow hover:bg-primary-hover focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-all transform active:scale-[0.99] mt-2">
                        Đặt lại mật khẩu
                    </button>

                </form>

            </div>

        </div>

        <!-- IMAGE SIDE -->
        <div class="hidden lg:block lg:w-[55%] relative overflow-hidden bg-slate-900 h-screen">
            <div class="absolute inset-0 w-full h-full bg-cover bg-center"
                 style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBp7GviHgE10zbzCL7099GUVP3Uv7mZa0t1c2i4UkHcDYn31fCYoiBQnhYkByHwssA6QtLOpNzTvWwAlBcLn2WgoQSoUwwcZ7TiqueiSNAUfXJ7Esk5h8PFbXXeb5KMk-LmOORm_2KMSv--_9gO8pYsTCV3Ss6GKSF-uYGdXc9mBdjmdDjfRXZypN2sILSEzmdjiJDu9z_ijmwHnSpLtGHu0_wjkxcdcIZ3jIrpJxOzaQM3qUnJro5K6bqx0r1tME1_pA8P1h5pl8yh'); filter: saturate(1.1) brightness(0.8);"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
            <div class="absolute inset-0 bg-gradient-to-r from-black/60 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-16 w-full max-w-2xl">
                <!-- Badge -->
                <div class="mb-6 inline-flex items-center px-3 py-1 rounded-full bg-white/10 backdrop-blur-md border border-white/20">
                    <span class="material-symbols-outlined text-green-400 mr-2" style="font-size:16px;">verified_user</span>
                    <span class="text-xs font-medium text-white tracking-wide uppercase">Phiên làm việc mã hóa</span>
                </div>
                <h2 class="text-5xl font-bold leading-tight text-white mb-6 font-poppins drop-shadow-xl">
                    Bảo mật là ưu tiên<br />hàng đầu của chúng tôi.
                </h2>
                <div class="flex items-center gap-4 text-white/80">
                    <span class="material-symbols-outlined text-primary">shield_lock</span>
                    <p class="text-lg font-light tracking-wide">Giữ cho quyền truy cập bất động sản của bạn an toàn.</p>
                </div>
                <div class="flex items-center gap-2 mt-12">
                    <div class="h-1.5 w-12 rounded-full bg-white/20"></div>
                    <div class="h-1.5 w-12 rounded-full bg-white/20"></div>
                    <div class="h-1.5 w-12 rounded-full bg-primary shadow-[0_0_10px_rgba(249,115,22,0.6)]"></div>
                </div>
            </div>
        </div>

    </div>

    <script>
        // ── Toggle password visibility ──
        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            const isPassword = input.type === 'password';
            input.type = isPassword ? 'text' : 'password';
            icon.textContent = isPassword ? 'visibility_off' : 'visibility';
        }

        // ── Live password requirement checker ──
        const passwordInput = document.getElementById('newPassword');

        const rules = {
            'req-length':  (v) => v.length >= 8,
            'req-special': (v) => /[!@@#$%^&*(),.?":{}|<>]/.test(v),
            'req-number':  (v) => /\d/.test(v),
        };

        passwordInput.addEventListener('input', function () {
            const val = this.value;
            Object.entries(rules).forEach(([id, test]) => {
                const li = document.getElementById(id);
                const iconContainer = li.querySelector('.req-icon');
                const dot = li.querySelector('.req-dot');
                const passed = test(val);

                li.className = li.className.replace(/text-(slate-500|green-600)/g, '').trim();
                li.classList.add(passed ? 'text-green-600' : 'text-slate-500');

                if (passed) {
                    iconContainer.className = iconContainer.className.replace('bg-slate-100', 'bg-green-100').replace('bg-green-100 bg-green-100', 'bg-green-100');
                    iconContainer.innerHTML = '<span class="material-symbols-outlined" style="font-size:14px;font-weight:700;color:#16a34a">check</span>';
                } else {
                    iconContainer.className = iconContainer.className.replace('bg-green-100', 'bg-slate-100');
                    iconContainer.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-slate-300 req-dot"></span>';
                }
            });
        });
    </script>

</body>

</html>
