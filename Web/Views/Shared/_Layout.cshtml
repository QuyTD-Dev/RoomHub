<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - RoomHub</title>

    <script src="https://cdn.tailwindcss.com?plugins=forms,typography,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/RoomPosts/index.css" />
    <script src="~/js/RoomPosts/index.js"></script>
</head>
<body class="bg-[#f4f4f4] dark:bg-background-dark text-slate-900 dark:text-slate-100 min-h-screen">

    <header class="sticky top-0 z-50 bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800">
        <div class="max-w-[1440px] mx-auto px-4 h-16 flex items-center gap-4">
            <div class="flex items-center gap-3 flex-shrink-0">
                <button class="p-1 hover:bg-slate-100 rounded-lg">
                    <span class="material-symbols-outlined text-2xl">menu</span>
                </button>
                <span class="text-primary text-2xl font-bold tracking-tight">RoomHub</span>
            </div>
            <button class="hidden md:flex items-center gap-2 px-3 py-1.5 border border-primary/40 bg-orange-50/50 rounded-full text-sm font-medium whitespace-nowrap">
                <span class="material-symbols-outlined text-primary text-xl">location_on</span>
                <span>Whole Country</span>
                <span class="material-symbols-outlined text-slate-400">expand_more</span>
            </button>
            <div class="flex-1 max-w-2xl relative group">
                <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none">
                    <span class="material-symbols-outlined text-slate-400">search</span>
                </div>
                <input class="w-full pl-12 pr-14 py-2.5 bg-slate-100 dark:bg-slate-800 border-none rounded-full focus:ring-2 focus:ring-primary text-sm" placeholder="Search for properties, locations..." type="text" />
                <button class="absolute right-1.5 top-1/2 -translate-y-1/2 w-9 h-9 bg-primary text-white rounded-full flex items-center justify-center hover:opacity-90 transition">
                    <span class="material-symbols-outlined text-xl">search</span>
                </button>
            </div>
            <div class="flex items-center gap-2 lg:gap-4">
                <div class="flex items-center gap-1 md:gap-3 px-2 border-r border-slate-200">
                    <button class="p-2 text-slate-700 hover:text-primary transition">
                        <span class="material-symbols-outlined text-2xl">favorite</span>
                    </button>
                    <button class="p-2 text-slate-700 hover:text-primary transition">
                        <span class="material-symbols-outlined text-2xl">chat</span>
                    </button>
                    <button class="p-2 text-slate-700 hover:text-primary transition">
                        <span class="material-symbols-outlined text-2xl">notifications</span>
                    </button>
                </div>
                <button class="hidden sm:block text-sm font-semibold px-4 py-2 rounded-lg border border-slate-200 hover:bg-slate-50 transition">Login</button>
                <button class="bg-primary text-white px-5 py-2 rounded-lg text-sm font-bold shadow-sm hover:opacity-90 transition whitespace-nowrap">
                    Post Ad
                </button>
                <button class="flex items-center gap-1 p-1 hover:bg-slate-100 rounded-full">
                    <span class="material-symbols-outlined text-3xl text-slate-400">account_circle</span>
                    <span class="material-symbols-outlined text-slate-400">expand_more</span>
                </button>
            </div>
        </div>
    </header>

    @RenderBody()

    <footer class="bg-white dark:bg-slate-900 border-t border-slate-200 dark:border-slate-800 pt-12 mt-12">
        <div class="max-w-7xl mx-auto px-4 pb-12">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
                <div class="space-y-6">
                    <h4 class="font-bold text-slate-900 dark:text-white">Download RoomHub App</h4>
                    <div class="flex gap-4 items-start">
                        <div class="bg-slate-100 p-2 rounded-lg">
                            <div class="w-24 h-24 bg-white border border-slate-200 flex items-center justify-center">
                                <span class="material-symbols-outlined text-4xl text-slate-300">qr_code_2</span>
                            </div>
                        </div>
                        <div class="space-y-3">
                            <a class="block hover:opacity-80 transition" href="#">
                                <img alt="App Store" class="h-10" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA0XcXerMRPvQDFehrQVPOYeEgD2oS_LJZ5ipKavujnOfCJ0fAXvRLVGKeAtPeaHpMDva8hWYGcvFtdy2BKR4RNNb8unJkuhkFBv5Pu2F4V6DAGDqKBOSaVm2GCsbTkfzK5e_LxszyVSboTUXgQUv5Tcs6lNfw52EafmkshHydXFJS4p9fswWkuOd7f7GXA3i4L0KmALyy8B6oywVOQFmjv_h-uD3EuBM9nOml-9-eD1o5i1Xn_DU6saHjnitdN-HDhMDamdGGQjIM" />
                            </a>
                            <a class="block hover:opacity-80 transition" href="#">
                                <img alt="Google Play" class="h-10" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAyZw_Qltb11cXXFlZK7oQbL4vV_qTtc151YMXvdzF5dHhiKSdAsDJhdsRa1dfYIkappETTsAQJ-IL5wotBzqVgSplWWq4GtGx-rny-7dsyZwCU-iZ2LHO6HJAAv10oIiVA3ZtqVSnfNck8JBVO0T6YNtE0Emn2j8cPveM8Gc_J-4esfsoB18oUDQlG1JRQ_0aX0LkxUiClp_zZYQE0vPEN5zIyGvDVhfLBugbWF6EJYrCustWk2OgFTr3Xtrs3Lm4YthuyYG-CQHE" />
                            </a>
                        </div>
                    </div>
                </div>
                <div class="space-y-6">
                    <h4 class="font-bold text-slate-900 dark:text-white">About RoomHub</h4>
                    <nav class="flex flex-col gap-3">
                        <a class="text-sm text-slate-500 hover:text-primary transition" href="#">Terms of Service</a>
                        <a class="text-sm text-slate-500 hover:text-primary transition" href="#">Privacy Policy</a>
                        <a class="text-sm text-slate-500 hover:text-primary transition" href="#">Dispute Resolution</a>
                        <a class="text-sm text-slate-500 hover:text-primary transition" href="#">Help Center</a>
                        <a class="text-sm text-slate-500 hover:text-primary transition" href="#">Careers</a>
                    </nav>
                </div>
                <div class="space-y-6">
                    <h4 class="font-bold text-slate-900 dark:text-white">Follow Us</h4>
                    <div class="flex gap-4">
                        <a class="w-10 h-10 bg-[#0077b5] text-white rounded-full flex items-center justify-center hover:opacity-80 transition" href="#">
                            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"></path></svg>
                        </a>
                        <a class="w-10 h-10 bg-[#FF0000] text-white rounded-full flex items-center justify-center hover:opacity-80 transition" href="#">
                            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"></path></svg>
                        </a>
                        <a class="w-10 h-10 bg-[#1877F2] text-white rounded-full flex items-center justify-center hover:opacity-80 transition" href="#">
                            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"></path></svg>
                        </a>
                    </div>
                    <div class="space-y-2 pt-2">
                        <p class="text-sm text-slate-600 flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary text-lg">mail</span>
                            contact@roomhub.com
                        </p>
                        <p class="text-sm text-slate-600 flex items-center gap-2">
                            <span class="material-symbols-outlined text-primary text-lg">call</span>
                            1900 1234 (1,000đ/min)
                        </p>
                        <p class="text-sm text-slate-600 flex items-start gap-2">
                            <span class="material-symbols-outlined text-primary text-lg mt-0.5">location_on</span>
                            Level 18, UOA Tower, No. 6 Tan Trao, Tan Phu Ward, District 7, Ho Chi Minh City, Vietnam
                        </p>
                    </div>
                </div>
            </div>
        </div>
        <div class="bg-slate-100 dark:bg-slate-800/50 py-8">
            <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-6">
                <div class="text-xs text-slate-500 space-y-2 text-center md:text-left">
                    <p class="font-bold uppercase tracking-wide text-slate-700 dark:text-slate-300">RoomHub Technology Joint Stock Company</p>
                    <p>Tax ID: 0312120782 issued by HCMC Department of Planning and Investment on 11/01/2013</p>
                    <p>Business License: 10/GP-BTTTT issued by Ministry of Information and Communications on 10/01/2025</p>
                    <p>© 2024 RoomHub - All rights reserved.</p>
                </div>
                <div class="flex items-center gap-4">
                    <div class="bg-red-600 text-white px-3 py-1.5 rounded flex items-center gap-2 text-[10px] font-bold uppercase cursor-pointer hover:bg-red-700 transition">
                        <span class="material-symbols-outlined text-sm">verified</span>
                        Registered
                        <span class="border-l border-white/30 pl-2">MoIT</span>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <div class="lg:hidden fixed bottom-0 left-0 right-0 bg-white dark:bg-slate-900 border-t border-slate-200 dark:border-slate-800 h-16 flex items-center justify-around px-4 z-50">
        <button class="flex flex-col items-center gap-0.5 text-primary">
            <span class="material-symbols-outlined">home</span>
            <span class="text-[10px] font-medium">Home</span>
        </button>
        <button class="flex flex-col items-center gap-0.5 text-slate-400">
            <span class="material-symbols-outlined">search</span>
            <span class="text-[10px] font-medium">Explore</span>
        </button>
        <button class="flex flex-col items-center gap-0.5 text-slate-400">
            <span class="material-symbols-outlined">add_circle</span>
            <span class="text-[10px] font-medium">Post</span>
        </button>
        <button class="flex flex-col items-center gap-0.5 text-slate-400">
            <span class="material-symbols-outlined">favorite</span>
            <span class="text-[10px] font-medium">Saved</span>
        </button>
        <button class="flex flex-col items-center gap-0.5 text-slate-400">
            <span class="material-symbols-outlined">account_circle</span>
            <span class="text-[10px] font-medium">Profile</span>
        </button>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>