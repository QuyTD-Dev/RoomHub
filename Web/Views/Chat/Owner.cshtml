@{
    ViewData["Title"] = "Chat - Chủ nhà";
}

<style>
    .chat-scrollbar::-webkit-scrollbar {
        width: 5px;
    }

    .chat-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }

    .chat-scrollbar::-webkit-scrollbar-thumb {
        background: #e5e7eb;
        border-radius: 10px;
    }

    /* Theme Xanh Blue cho Owner để phân biệt với Tenant */
    .bg-theme {
        background-color: #0d6efd !important;
        color: white !important;
    }

    .text-theme {
        color: #0d6efd !important;
    }

    .hover-theme:hover {
        color: #0d6efd !important;
        transition: 0.2s;
        cursor: pointer;
    }

    .active-conversation {
        background-color: #f0f8ff; /* Xanh nhạt */
        border-left: 4px solid #0d6efd !important;
    }

    .cursor-pointer {
        cursor: pointer;
    }

    .bubble-left {
        border-radius: 1rem 1rem 1rem 0;
    }

    .bubble-right {
        border-radius: 1rem 1rem 0 1rem;
    }
</style>

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />

<div class="container-fluid py-4">
    <div class="row bg-white shadow mx-auto" style="max-width: 1100px; height: 80vh; min-height: 600px; border-radius: 1rem; border: 1px solid #e5e7eb; overflow: hidden;">

        <div class="col-md-4 col-lg-4 border-end d-flex flex-column p-0 h-100 bg-white">
            <div class="p-3 border-bottom">
                <h5 class="fw-bold mb-3 text-dark">Hỗ trợ khách thuê</h5>
                <div class="input-group">
                    <span class="input-group-text bg-light border-0 rounded-start-pill text-muted"><i class="fa-solid fa-magnifying-glass"></i></span>
                    <input type="text" class="form-control bg-light border-0 rounded-end-pill shadow-none" placeholder="Tìm người thuê...">
                </div>
            </div>
            <div class="flex-grow-1 overflow-auto chat-scrollbar">
                <div class="d-flex align-items-center p-3 border-bottom active-conversation cursor-pointer">
                    <div class="position-relative flex-shrink-0">
                        <img src="https://ui-avatars.com/api/?name=Nguyễn+Văn+A&background=random" class="rounded-circle object-fit-cover" style="width: 48px; height: 48px;" alt="Avatar">
                        <span class="position-absolute bottom-0 end-0 p-1 bg-success border border-white rounded-circle"></span>
                    </div>
                    <div class="ms-3 flex-grow-1 overflow-hidden">
                        <div class="d-flex justify-content-between align-items-center">
                            <h6 class="mb-0 text-truncate fw-bold text-dark" style="font-size: 0.95rem;">Nguyễn Văn A (Phòng 102)</h6>
                            <small class="text-muted" style="font-size: 0.75rem;">10:28 AM</small>
                        </div>
                        <div class="mt-1">
                            <small class="text-muted text-truncate mb-0">Dạ vâng, để cháu kiểm tra ngay ạ.</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8 col-lg-8 d-flex flex-column p-0 h-100 bg-white">
            <div class="p-3 border-bottom d-flex justify-content-between align-items-center bg-white z-1">
                <div class="d-flex align-items-center">
                    <img src="https://ui-avatars.com/api/?name=Nguyễn+Văn+A&background=random" class="rounded-circle object-fit-cover" style="width: 42px; height: 42px;" alt="Avatar">
                    <div class="ms-3">
                        <h6 class="mb-0 fw-bold text-dark">Nguyễn Văn A</h6>
                        <small class="text-muted fw-medium" style="font-size: 0.8rem;">Phòng 102</small>
                    </div>
                </div>
                <div class="text-muted fs-5">
                    <i class="fa-solid fa-phone ms-3 hover-theme"></i>
                    <i class="fa-solid fa-circle-info ms-3 hover-theme"></i>
                </div>
            </div>

            <div class="flex-grow-1 p-4 overflow-auto chat-scrollbar bg-light d-flex flex-column gap-3" id="chatBox">
                <div class="d-flex align-items-end" style="max-width: 80%;">
                    <img src="https://ui-avatars.com/api/?name=Nguyễn+Văn+A&background=random" class="rounded-circle me-2 mb-4 flex-shrink-0" style="width: 32px; height: 32px;" alt="Avatar">
                    <div>
                        <div class="bg-white p-3 shadow-sm border border-light bubble-left text-dark">
                            <p class="mb-0" style="font-size: 0.9rem;">Dạ vâng, để cháu kiểm tra ngay ạ.</p>
                        </div>
                        <small class="text-muted d-block mt-1" style="font-size: 0.7rem;">10:28 AM</small>
                    </div>
                </div>

                <div class="d-flex flex-column align-items-end align-self-end" style="max-width: 80%;">
                    <div class="bg-theme p-3 shadow-sm bubble-right">
                        <p class="mb-0" style="font-size: 0.9rem;">Oke cháu, có gì thắc mắc cứ nhắn chú nhé.</p>
                    </div>
                    <small class="text-muted d-block mt-1 text-end" style="font-size: 0.7rem;">Vừa xong</small>
                </div>
            </div>

            <div class="p-3 border-top bg-white d-flex align-items-center gap-3">
                <button class="btn btn-link text-muted hover-theme p-0 border-0 shadow-none fs-5"><i class="fa-solid fa-paperclip"></i></button>
                <div class="flex-grow-1">
                    <input type="text" class="form-control rounded-pill bg-light border-0 py-2 px-4 shadow-none" id="messageInput" placeholder="Nhập tin nhắn hỗ trợ...">
                </div>
                <button id="sendButton" class="btn bg-theme rounded-circle d-flex align-items-center justify-content-center border-0 shadow-sm flex-shrink-0 hover-theme" style="width: 44px; height: 44px; color: white;">
                    <i class="fa-solid fa-paper-plane"></i>
                </button>
            </div>
        </div>
    </div>
</div>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

<script>
    // 1. Khởi tạo kết nối đến ChatHub
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/chathub")
        .build();

    // 2. Lắng nghe tin nhắn mới từ Server gửi về
    connection.on("ReceiveMessage", function (senderRole, message) {
        const chatBox = document.getElementById("chatBox");
        const now = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

        let msgHtml = "";
        if (senderRole === "Owner") {
            // Tin nhắn của chính mình (Màu Cam - Căn phải)
            msgHtml = `
            <div class="d-flex flex-column align-items-end align-self-end" style="max-width: 80%;">
                <div class="bg-theme p-3 shadow-sm bubble-right">
                    <p class="mb-0" style="font-size: 0.9rem;">${message}</p>
                </div>
                <small class="text-muted d-block mt-1 text-end" style="font-size: 0.7rem;">${now}</small>
            </div>`;
        } else {
            // Tin nhắn từ Owner (Màu Trắng - Căn trái)
            msgHtml = `
            <div class="d-flex align-items-end" style="max-width: 80%;">
                <img src="https://ui-avatars.com/api/?name=Bác+Ba&background=random" class="rounded-circle me-2 mb-4 flex-shrink-0" style="width: 32px; height: 32px;">
                <div>
                    <div class="bg-white p-3 shadow-sm border border-light bubble-left text-dark">
                        <p class="mb-0" style="font-size: 0.9rem;">${message}</p>
                    </div>
                    <small class="text-muted d-block mt-1" style="font-size: 0.7rem;">${now}</small>
                </div>
            </div>`;
        }

        // Nhúng tin nhắn vào giao diện và cuộn xuống dưới cùng
        chatBox.insertAdjacentHTML('beforeend', msgHtml);
        chatBox.scrollTop = chatBox.scrollHeight;
    });

    // 3. Bắt đầu kết nối
    connection.start().catch(function (err) {
        return console.error(err.toString());
    });

    // 4. Bắt sự kiện bấm nút Gửi
    document.getElementById("sendButton").addEventListener("click", function (event) {
        const message = document.getElementById("messageInput").value;
        if(message.trim() !== "") {
            // Gửi lên Server với định danh là "Tenant"
            connection.invoke("SendMessage", "Owner", message).catch(function (err) {
                return console.error(err.toString());
            });
            document.getElementById("messageInput").value = ""; // Xóa input sau khi gửi
        }
        event.preventDefault();
    });

    // Hỗ trợ bấm Enter để gửi
    document.getElementById("messageInput").addEventListener("keypress", function (e) {
        if (e.key === 'Enter') {
            document.getElementById("sendButton").click();
        }
    });
</script>